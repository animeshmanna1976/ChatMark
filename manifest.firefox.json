{
    "manifest_version": 3,
    "name": "ChatMark",
    "version": "1.0",
    "description": "highlight and annotate important parts of your ai conversations",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://claude.ai/*",
                "https://chatgpt.com/*",
                "https://gemini.google.com/*"
            ],
            "js": ["content.js"],
            "css": ["styles.css"],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "ChatMark"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "chatmark@animeshmanna",
            "strict_min_version": "109.0"
        }
    }
}
